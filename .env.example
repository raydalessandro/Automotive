# ─────────────────────────────────────────────────────────────
# Supabase — sito (lead) + dashboard (auth, inbox, analytics, mailing)
# ─────────────────────────────────────────────────────────────

# Pubbliche (esposte al browser: auth/SSR e realtime dashboard)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-only: bypassa RLS. Usato dagli insert pubblici (form, eventi) e dal motore d'invio.
# SUPABASE_URL può coincidere con NEXT_PUBLIC_SUPABASE_URL (se assente si usa quella).
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# ─────────────────────────────────────────────────────────────
# Notifiche lead: Telegram (istantaneo) + fallback email (Resend)
# ─────────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

RESEND_API_KEY=
LEAD_NOTIFY_EMAIL=

# ─────────────────────────────────────────────────────────────
# Motore d'invio campagne (§4 dashboard) — attivabili in seguito
# ─────────────────────────────────────────────────────────────
# Segreto per proteggere l'endpoint cron (Vercel Cron invia questo header)
CRON_SECRET=
# Dominio d'invio dedicato per le campagne (mai il dominio del sito)
MAIL_FROM=
# Tetto globale invii/giorno (default 50 se assente)
TETTO_GLOBALE_GIORNO=50

# ─────────────────────────────────────────────────────────────
# Base URL pubblico (link OG/WhatsApp, deep link Telegram). In locale: http://localhost:3000
# ─────────────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=http://localhost:3000
